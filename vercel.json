{
  "version": 2,
  "builds": [
    {
      "src": "apps/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/apps/frontend/browser"
      }
    },
    {
      "src": "apps/api/api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "apps/frontend/dist/apps/frontend/browser/index.html"
    },
    { "src": "/api/drive/(.*)", 
      "dest": "apps/api/api/drive/$1"
    }

  ]
}