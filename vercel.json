{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/apps/frontend/browser"
      }
    },
    {
      "src": "apps/api/api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "apps/api/api/$1" },
    { "src": "/(.*)", "dest": "/dist/apps/frontend/browser/index.html" }
  ]
}