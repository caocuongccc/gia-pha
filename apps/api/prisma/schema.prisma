generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RelationshipType {
  PARENT
  SPOUSE
  SIBLING
}

enum FamilyRole {
  OWNER
  EDITOR
  VIEWER
}

// ── Models ─────────────────────────────
model Family {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      Member[]
  accessList   FamilyMember[]
  inviteTokens InviteToken[]
  chiList      Chi[]
  scholarships ScholarshipRecord[] @relation("FamilyScholarships")
  fundRecords  FundRecord[]        @relation("FamilyFundRecords")

  @@map("families")
}

model Member {
  id         String    @id @default(uuid())
  familyId   String
  fullName   String
  gender     Gender
  birthDate  DateTime?
  deathDate  DateTime?
  photoUrl   String?
  generation Int       @default(1)
  biography  String?

  alias       String?
  childOrder  Int?
  burialPlace String?
  birthPlace  String?
  isOutPerson Boolean @default(false)
  deathYearAm String?
  coupleGroupId String?

  chiId  String?
  phaiId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  chi    Chi?   @relation(fields: [chiId], references: [id])
  phai   Phai?  @relation(fields: [phaiId], references: [id])

  fromRelations Relationship[] @relation("FromMember")
  toRelations   Relationship[] @relation("ToMember")
  scholarships  ScholarshipRecord[] @relation("MemberScholarships")
  fundRecords   FundRecord[]        @relation("MemberFundRecords")

  @@map("members")
}

model Relationship {
  id           String           @id @default(uuid())
  fromMemberId String
  toMemberId   String
  type         RelationshipType
  marriageDate DateTime?
  divorceDate  DateTime?
  createdAt    DateTime         @default(now())

  fromMember Member @relation("FromMember", fields: [fromMemberId], references: [id])
  toMember   Member @relation("ToMember", fields: [toMemberId], references: [id])

  @@unique([fromMemberId, toMemberId, type])
  @@map("relationships")
}

model FamilyMember {
  id       String     @id @default(uuid())
  familyId String
  userId   String
  role     FamilyRole @default(VIEWER)
  joinedAt DateTime   @default(now())

  family Family @relation(fields: [familyId], references: [id])

  @@unique([familyId, userId])
  @@map("family_members")
}

model InviteToken {
  id        String     @id @default(uuid())
  token     String     @unique @default(uuid())
  familyId  String
  invitedBy String
  email     String
  role      FamilyRole @default(VIEWER)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime   @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("invite_tokens")
}

model Chi {
  id          String   @id @default(uuid())
  familyId    String
  name        String
  description String?
  founderNote String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  phaiList Phai[]
  members  Member[]

  @@unique([familyId, name])
  @@map("chi")
}

model Phai {
  id          String   @id @default(uuid())
  chiId       String
  name        String
  description String?
  founderNote String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chi     Chi      @relation(fields: [chiId], references: [id], onDelete: Cascade)
  members Member[]

  @@unique([chiId, name])
  @@map("phai")
}

// ── Khuyến học ──────────────────────────────────────────────────
model ScholarshipRecord {
  id        String  @id @default(uuid())
  familyId  String
  memberId  String? // liên kết với Member trong cây (optional)

  studentName  String  // tên cháu
  year         Int     // năm học
  school       String? // trường
  grade        String? // lớp / cấp
  achievement  String  // "Học sinh Giỏi" | "Xuất sắc" | "Giải thi" | "Đỗ ĐH" | tự nhập
  rewardAmount Int?    // số tiền thưởng (VNĐ), null = chưa xác định
  awardedBy    String? // người duyệt/trao thưởng
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  family Family  @relation("FamilyScholarships", fields: [familyId], references: [id], onDelete: Cascade)
  member Member? @relation("MemberScholarships", fields: [memberId], references: [id])

  @@map("scholarship_records")
}

// ── Quỹ họ / Cúng tiến ──────────────────────────────────────────
enum FundRecordType {
  DIEU_DONG  // đóng theo đinh (bắt buộc hàng năm)
  CUNG_TIEN  // đóng góp thêm tự nguyện
  CHI        // chi ra (tổ chức giỗ, thưởng học sinh, tu bổ...)
}

model FundRecord {
  id       String         @id @default(uuid())
  familyId String
  memberId String?        // liên kết member nếu có

  type            FundRecordType
  year            Int
  eventName       String?  // tên kỳ cúng / sự kiện (Giỗ tổ, Lễ hội...)
  contributorName String?  // tên người đóng góp
  amount          Int      // số tiền VNĐ (dương = thu, âm = chi)
  description     String?  // ghi chú
  recordedBy      String?  // người ghi nhận
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family Family  @relation("FamilyFundRecords", fields: [familyId], references: [id], onDelete: Cascade)
  member Member? @relation("MemberFundRecords", fields: [memberId], references: [id])

  @@map("fund_records")
}
